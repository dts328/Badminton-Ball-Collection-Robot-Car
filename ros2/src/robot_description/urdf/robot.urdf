<?xml version="1.0"?>
<robot name="smart_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <!-- ==================== 属性定义 ==================== -->
  <!-- 底盘参数 -->
  <xacro:property name="chassis_width" value="0.3"/>
  <xacro:property name="chassis_length" value="0.4"/>
  <xacro:property name="chassis_height" value="0.08"/>
  
  <!-- 轮子参数（实际测量） -->
  <xacro:property name="wheel_radius" value="0.0485"/>    <!-- 轮子直径9.7cm -->
  <xacro:property name="wheel_width" value="0.044"/>      <!-- 轮子厚度4.4cm -->
  <xacro:property name="wheelbase" value="0.12"/>         <!-- 轮子前后距离12cm -->
  <xacro:property name="wheeltrack" value="0.236"/>       <!-- 轮子左右距离23.6cm -->
  
  <!-- 机械臂参数 -->
  <xacro:property name="arm_base_height" value="0.05"/>
  <xacro:property name="link1_length" value="0.10"/>
  <xacro:property name="link2_length" value="0.12"/>
  <xacro:property name="link3_length" value="0.10"/>
  <xacro:property name="link4_length" value="0.08"/>
  <xacro:property name="link5_length" value="0.06"/>
  <xacro:property name="gripper_length" value="0.08"/>
  
  <!-- 传感器参数（实际测量） -->
  <xacro:property name="imu_x_offset" value="-0.05"/>    <!-- 陀螺仪距中心后5cm -->
  <xacro:property name="lidar_height" value="0.2"/>       <!-- 雷达高度20cm -->
  <xacro:property name="camera_height" value="0.20"/>
  <xacro:property name="orbbec_height" value="0.18"/>
  
  <!-- ==================== 材质定义 ==================== -->
  <!-- 底盘材质 - 深蓝色 -->
  <material name="chassis_material">
    <color rgba="0.15 0.25 0.55 1.0"/>
  </material>
  
  <!-- 轮子材质 - 黑色橡胶 -->
  <material name="wheel_material">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  
  <!-- 机械臂材质 - 银灰色铝合金 -->
  <material name="arm_material">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>
  
  <!-- 传感器材质 - 深灰色 -->
  <material name="sensor_material">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>
  
  <!-- 夹爪材质 - 浅灰色 -->
  <material name="gripper_material">
    <color rgba="0.55 0.55 0.55 1.0"/>
  </material>
  
  <!-- 底盘装饰条 - 橙色警示色 -->
  <material name="accent_material">
    <color rgba="0.9 0.5 0.1 1.0"/>
  </material>
  
  <!-- 机械臂关节 - 深灰色 -->
  <material name="joint_material">
    <color rgba="0.4 0.4 0.42 1.0"/>
  </material>
  
  <!-- 摄像头镜头 - 深蓝色 -->
  <material name="lens_material">
    <color rgba="0.1 0.15 0.3 1.0"/>
  </material>
  
  <!-- ==================== 底盘 ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="chassis_material"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.1"/>
    </inertial>
  </link>
  
  <!-- 底盘前装饰条 -->
  <joint name="front_accent_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_accent"/>
    <origin xyz="${chassis_length/2} 0 ${chassis_height}" rpy="0 0 0"/>
  </joint>
  <link name="front_accent">
    <visual>
      <geometry>
        <box size="0.02 0.25 0.01"/>
      </geometry>
      <material name="accent_material"/>
    </visual>
  </link>
  
  <!-- 底盘后装饰条 -->
  <joint name="rear_accent_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_accent"/>
    <origin xyz="${-chassis_length/2} 0 ${chassis_height}" rpy="0 0 0"/>
  </joint>
  <link name="rear_accent">
    <visual>
      <geometry>
        <box size="0.02 0.25 0.01"/>
      </geometry>
      <material name="accent_material"/>
    </visual>
  </link>
  
  <!-- ==================== 麦克纳姆轮 ==================== -->
  <!-- 左前轮 -->
  <joint name="wheel_fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fl"/>
    <origin xyz="${wheelbase/2} ${wheeltrack/2} 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_fl">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <!-- 右前轮 -->
  <joint name="wheel_fr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_fr"/>
    <origin xyz="${wheelbase/2} ${-wheeltrack/2} 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_fr">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <!-- 左后轮 -->
  <joint name="wheel_bl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_bl"/>
    <origin xyz="${-wheelbase/2} ${wheeltrack/2} 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_bl">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <!-- 右后轮 -->
  <joint name="wheel_br_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_br"/>
    <origin xyz="${-wheelbase/2} ${-wheeltrack/2} 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_br">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_material"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <!-- ==================== 陀螺仪（IMU） ==================== -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_frame"/>
    <origin xyz="${imu_x_offset} 0 ${chassis_height}" rpy="0 0 0"/>
  </joint>
  <link name="imu_frame">
    <visual>
      <origin xyz="0 0 0.005" rpy="0 0 0"/>
      <geometry>
        <box size="0.035 0.035 0.01"/>
      </geometry>
      <material name="sensor_material"/>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
  <!-- ==================== LD06激光雷达（在陀螺仪正上方） ==================== -->
  <joint name="laser_joint" type="fixed">
    <parent link="imu_frame"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>
  <link name="laser_frame">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.04"/>
      </geometry>
      <material name="sensor_material"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <!-- ==================== 奥比中光深度相机 ==================== -->
  <joint name="orbbec_joint" type="fixed">
    <parent link="base_link"/>
    <child link="orbbec_frame"/>
    <origin xyz="0.15 0 ${orbbec_height}" rpy="0 0 0"/>
  </joint>
  <link name="orbbec_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.03 0.025"/>
      </geometry>
      <material name="sensor_material"/>
    </visual>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <!-- 奥比中光镜头 -->
  <joint name="orbbec_lens_joint" type="fixed">
    <parent link="orbbec_frame"/>
    <child link="orbbec_lens"/>
    <origin xyz="0.04 0 0" rpy="0 1.5708 0"/>
  </joint>
  <link name="orbbec_lens">
    <visual>
      <geometry>
        <cylinder radius="0.012" length="0.005"/>
      </geometry>
      <material name="lens_material"/>
    </visual>
  </link>
  
  <!-- ==================== USB摄像头 ==================== -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_frame"/>
    <origin xyz="0.2 0 ${camera_height}" rpy="0 0 0"/>
  </joint>
  <link name="camera_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.04"/>
      </geometry>
      <material name="sensor_material"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
  <!-- ==================== 机械臂 ==================== -->
  <!-- 机械臂基座 -->
  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0 0 ${chassis_height}" rpy="0 0 0"/>
  </joint>
  <link name="arm_base">
    <visual>
      <origin xyz="0 0 ${arm_base_height/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="${arm_base_height}"/>
      </geometry>
      <material name="joint_material"/>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  
  <!-- 关节1 - 底座旋转 -->
  <joint name="joint1" type="revolute">
    <parent link="arm_base"/>
    <child link="link1"/>
    <origin xyz="0 0 ${arm_base_height}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" velocity="3.14" effort="10"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="link1">
    <visual>
      <origin xyz="0 0 ${link1_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="${link1_length}"/>
      </geometry>
      <material name="arm_material"/>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0005"/>
    </inertial>
  </link>
  
  <!-- 关节1连接环 -->
  <joint name="joint1_ring_joint" type="fixed">
    <parent link="link1"/>
    <child link="joint1_ring"/>
    <origin xyz="0 0 ${link1_length}" rpy="0 0 0"/>
  </joint>
  <link name="joint1_ring">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.015"/>
      </geometry>
      <material name="joint_material"/>
    </visual>
  </link>
  
  <!-- 关节2 - 肩关节 -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 ${link1_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" velocity="3.14" effort="10"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="link2">
    <visual>
      <origin xyz="0 0 ${link2_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="${link2_length}"/>
      </geometry>
      <material name="arm_material"/>
    </visual>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.0003"/>
    </inertial>
  </link>
  
  <!-- 关节3 - 肘关节 -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 ${link2_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.35" upper="2.35" velocity="3.14" effort="8"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="link3">
    <visual>
      <origin xyz="0 0 ${link3_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="${link3_length}"/>
      </geometry>
      <material name="arm_material"/>
    </visual>
    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0002"/>
    </inertial>
  </link>
  
  <!-- 关节4 - 腕关节俯仰 -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 ${link3_length}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" velocity="3.14" effort="5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="link4">
    <visual>
      <origin xyz="0 0 ${link4_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.015" length="${link4_length}"/>
      </geometry>
      <material name="arm_material"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <!-- 关节5 - 腕关节旋转 -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 ${link4_length}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" velocity="3.14" effort="5"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>
  <link name="link5">
    <visual>
      <origin xyz="0 0 ${link5_length/2}" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.012" length="${link5_length}"/>
      </geometry>
      <material name="arm_material"/>
    </visual>
    <inertial>
      <mass value="0.08"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  
  <!-- ==================== 夹爪 ==================== -->
  <!-- 夹爪基座 -->
  <joint name="gripper_base_joint" type="fixed">
    <parent link="link5"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 ${link5_length}" rpy="0 0 0"/>
  </joint>
  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.04 0.06 0.02"/>
      </geometry>
      <material name="gripper_material"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  
  <!-- 左夹爪 -->
  <joint name="gripper_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_left"/>
    <origin xyz="0 0.015 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0.025" velocity="0.1" effort="5"/>
  </joint>
  <link name="gripper_left">
    <visual>
      <origin xyz="0 0 ${gripper_length/2}" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 ${gripper_length}"/>
      </geometry>
      <material name="gripper_material"/>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
  <!-- 右夹爪 -->
  <joint name="gripper_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_right"/>
    <origin xyz="0 -0.015 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0" upper="0.025" velocity="0.1" effort="5"/>
  </joint>
  <link name="gripper_right">
    <visual>
      <origin xyz="0 0 ${gripper_length/2}" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 ${gripper_length}"/>
      </geometry>
      <material name="gripper_material"/>
    </visual>
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>
  
</robot>
